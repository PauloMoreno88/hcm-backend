PORT=

# PostgreSQL connection string
DATABASE_URL=

JWT_SECRET=
JWT_EXPIRES_IN=

# Storage: "local" (default) or "s3"
STORAGE_DRIVER=

# Local storage: files saved under ./uploads; served at /uploads/*
STORAGE_LOCAL_DIR=
STORAGE_PUBLIC_BASE_URL=

# S3-compatible (only when STORAGE_DRIVER=s3)
# S3_REGION=us-east-1
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=hcm-uploads
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://cdn.example.com
# S3_FORCE_PATH_STYLE=true
